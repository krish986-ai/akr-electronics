# ============================================================================
# DEPLOYMENT (Vercel)
# ============================================================================
# Set every variable below in the Vercel dashboard:
# Project Settings > Environment Variables (Production + Preview)
# Vercel sets VERCEL=1 automatically, which switches file uploads from local
# disk (dev only) to Firebase Storage. To force Firebase Storage locally:
STORAGE_PROVIDER=""

# ============================================================================
# FIREBASE (Auth + Firestore + Storage)
# ============================================================================
# Get these from Firebase Console > Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Firebase Admin SDK (Server-side only - DO NOT EXPOSE TO BROWSER)
FIREBASE_ADMIN_PRIVATE_KEY=""
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""

# ============================================================================
# SESSION & SECURITY
# ============================================================================
# Random secret for session management
SESSION_SECRET="your-random-secret-key-here-min-32-chars"

# Session expiry time in milliseconds (default: 30 days)
SESSION_EXPIRY_MS="2592000000"

# ============================================================================
# RAZORPAY PAYMENT (Not configured yet - placeholder for Phase 4)
# ============================================================================
RAZORPAY_KEY_ID=""
RAZORPAY_SECRET_KEY=""

# ============================================================================
# APPLICATION
# ============================================================================
NEXT_PUBLIC_APP_NAME="A.K.R Electronics"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ============================================================================
# ADMIN CONFIGURATION
# ============================================================================
# Email of the primary admin user (created during initial setup)
ADMIN_EMAIL="admin@akrelectronics.com"
