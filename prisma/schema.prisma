// A.K.R Electronics - Production Database Schema
// Phase 2: Complete Database Architecture

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER MANAGEMENT
// ============================================================================

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String   // Will be hashed in application
  name           String
  phone          String?
  image          String?
  role           UserRole @default(CUSTOMER)
  status         UserStatus @default(ACTIVE)
  emailVerified  Boolean  @default(false)
  verifiedAt     DateTime?
  lastLoginAt    DateTime?
  isDeleted      Boolean  @default(false)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  orders         Order[]
  cart           Cart?
  addresses      Address[]
  wishlistItems  WishlistItem[]
  reviews        Review[]
  coupons        UserCouponUsage[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([isDeleted])
  @@index([createdAt])
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

// ============================================================================
// PRODUCTS & CATALOG
// ============================================================================

model Brand {
  id            String   @id @default(cuid())
  name          String   @unique
  slug          String   @unique
  logo          String?
  description   String?
  status        BrandStatus @default(ACTIVE)
  isDeleted     Boolean  @default(false)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  products      Product[]

  @@index([slug])
  @@index([status])
  @@index([isDeleted])
}

enum BrandStatus {
  ACTIVE
  INACTIVE
  DELETED
}

model Category {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String?
  image            String?
  icon             String?

  // Nested categories
  parentId         String?
  parent           Category? @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children         Category[] @relation("CategoryParent")

  // SEO fields
  seoTitle         String?
  seoDescription   String?
  seoKeywords      String?

  // Status and visibility
  status           CategoryStatus @default(ACTIVE)
  isFeatured       Boolean  @default(false)
  displayOrder     Int      @default(0)
  isDeleted        Boolean  @default(false)
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  products         Product[]

  @@unique([slug, parentId])
  @@index([parentId])
  @@index([slug])
  @@index([status])
  @@index([isFeatured])
  @@index([isDeleted])
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model Product {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  sku               String   @unique
  description       String   @db.Text
  shortDescription  String?

  // Images
  thumbnailImage    String?
  images            ProductImage[]

  // Pricing and discounts
  basePrice         Decimal  @db.Decimal(10, 2)
  salePrice         Decimal? @db.Decimal(10, 2)
  discountPercent   Int?

  // Stock management
  stock             Int
  reservedStock     Int      @default(0)
  lowStockLimit     Int      @default(10)

  // Product details
  weight            Decimal? @db.Decimal(10, 2) // in kg
  dimensions        Json?    // { length, width, height, unit }
  specifications    Json?    // Flexible specifications

  // Categorization
  categoryId        String
  category          Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brandId           String?
  brand             Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)

  // Status and visibility
  status            ProductStatus @default(ACTIVE)
  isFeatured        Boolean  @default(false)
  isNewArrival      Boolean  @default(false)
  isBestseller      Boolean  @default(false)
  visibility        ProductVisibility @default(PUBLIC)
  displayOrder      Int      @default(0)

  // SEO fields
  seoTitle          String?
  seoDescription    String?
  seoKeywords       String?

  // Tracking
  viewCount         Int      @default(0)
  isDeleted         Boolean  @default(false)
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  kitProducts       KitProduct[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  wishlistItems     WishlistItem[]
  reviews           Review[]
  inventory         InventoryHistory[]

  @@index([slug])
  @@index([sku])
  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([isFeatured])
  @@index([isNewArrival])
  @@index([visibility])
  @@index([isDeleted])
  @@index([createdAt])
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
  OUT_OF_STOCK
}

enum ProductVisibility {
  PUBLIC
  PRIVATE
  HIDDEN
  DRAFT
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl    String
  altText     String?
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())

  @@index([productId])
}

// ============================================================================
// IOT KITS
// ============================================================================

model IotKit {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String   @db.Text
  shortDescription String?

  // Pricing
  basePrice        Decimal  @db.Decimal(10, 2)
  salePrice        Decimal? @db.Decimal(10, 2)
  discountPercent  Int?

  // Images
  thumbnailImage   String?
  images           KitImage[]

  // Status
  status           KitStatus @default(ACTIVE)
  isFeatured       Boolean  @default(false)
  visibility       KitVisibility @default(PUBLIC)
  displayOrder     Int      @default(0)

  // SEO
  seoTitle         String?
  seoDescription   String?
  seoKeywords      String?

  // Tracking
  viewCount        Int      @default(0)
  isDeleted        Boolean  @default(false)
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  products         KitProduct[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  wishlistItems    WishlistItem[]
  reviews          Review[]

  @@index([slug])
  @@index([status])
  @@index([isFeatured])
  @@index([isDeleted])
}

enum KitStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum KitVisibility {
  PUBLIC
  PRIVATE
  HIDDEN
  DRAFT
}

model KitImage {
  id          String   @id @default(cuid())
  kitId       String
  kit         IotKit   @relation(fields: [kitId], references: [id], onDelete: Cascade)
  imageUrl    String
  altText     String?
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())

  @@index([kitId])
}

model KitProduct {
  id        String   @id @default(cuid())
  kitId     String
  kit       IotKit   @relation(fields: [kitId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  createdAt DateTime @default(now())

  @@unique([kitId, productId])
  @@index([kitId])
  @@index([productId])
}

// ============================================================================
// INVENTORY MANAGEMENT
// ============================================================================

model InventoryHistory {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Inventory changes
  quantityChange  Int
  previousStock   Int
  newStock        Int

  // Reason for change
  reason          InventoryReason
  notes           String?

  // Reference IDs
  orderId         String?
  referenceId     String?

  createdAt       DateTime @default(now())

  @@index([productId])
  @@index([reason])
  @@index([createdAt])
}

enum InventoryReason {
  INITIAL_STOCK
  PURCHASE
  RETURN
  DAMAGE
  LOST
  ADJUSTMENT
  KIT_ASSEMBLY
  KIT_DISASSEMBLY
  PROMOTION
  CORRECTION
}

// ============================================================================
// WISHLIST
// ============================================================================

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  kitId     String?
  kit       IotKit?  @relation(fields: [kitId], references: [id], onDelete: Cascade)

  priority  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@unique([userId, kitId])
  @@index([userId])
  @@index([productId])
  @@index([kitId])
}

// ============================================================================
// SHOPPING CART
// ============================================================================

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  kitId     String?
  kit       IotKit?  @relation(fields: [kitId], references: [id], onDelete: Cascade)

  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId, kitId])
  @@index([cartId])
  @@index([productId])
  @@index([kitId])
}

// ============================================================================
// ORDERS
// ============================================================================

model Order {
  id                String       @id @default(cuid())
  orderNumber       String       @unique
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  // Items
  items             OrderItem[]

  // Status tracking
  orderStatus       OrderStatus  @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  shippingStatus    ShippingStatus @default(PENDING)

  // Payment details
  paymentMethod     String?
  paymentId         String?      // Razorpay payment ID
  transactionId     String?

  // Shipping
  shippingAddressId String?
  shippingAddress   Address?     @relation("ShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)

  billingAddressId  String?
  billingAddress    Address?     @relation("BillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)

  // Pricing
  subtotal          Decimal  @db.Decimal(12, 2)
  taxAmount         Decimal  @db.Decimal(10, 2)
  shippingCost      Decimal  @db.Decimal(10, 2)
  discountAmount    Decimal  @default(0) @db.Decimal(10, 2)
  grandTotal        Decimal  @db.Decimal(12, 2)

  // Coupon
  couponId          String?
  coupon            Coupon?  @relation(fields: [couponId], references: [id], onDelete: SetNull)

  // Invoice
  invoiceNumber     String?
  invoiceUrl        String?
  invoiceGeneratedAt DateTime?

  // Notes
  notes             String?
  adminNotes        String?

  // Tracking
  estimatedDelivery DateTime?
  deliveredAt       DateTime?
  cancelledAt       DateTime?
  returnedAt        DateTime?

  isDeleted         Boolean  @default(false)
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([shippingStatus])
  @@index([orderNumber])
  @@index([couponId])
  @@index([isDeleted])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  FAILED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIAL_REFUND
  DISPUTED
}

enum ShippingStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: Restrict)

  kitId       String?
  kit         IotKit?  @relation(fields: [kitId], references: [id], onDelete: Restrict)

  // Item details captured at purchase
  name        String   // Product/Kit name at time of purchase
  sku         String?
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalPrice  Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)

  // Item-level metadata
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([kitId])
}

// ============================================================================
// ADDRESSES
// ============================================================================

model Address {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Address details
  fullName    String
  phone       String
  email       String

  // Address components
  street      String
  city        String
  state       String
  postalCode  String
  country     String

  // Address type
  type        AddressType

  // Flags
  isDefault   Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  @@index([userId])
  @@index([type])
  @@index([isDefault])
  @@index([isDeleted])
}

enum AddressType {
  SHIPPING
  BILLING
  BOTH
}

// ============================================================================
// COUPONS & DISCOUNTS
// ============================================================================

model Coupon {
  id                String   @id @default(cuid())
  code              String   @unique
  description       String?

  // Discount type
  type              DiscountType
  value             Decimal  @db.Decimal(10, 2)
  minPurchaseAmount Decimal? @db.Decimal(10, 2)
  maxDiscountAmount Decimal? @db.Decimal(10, 2)

  // Usage limits
  maxUsagePerUser   Int?
  totalUsageLimit   Int?
  currentUsage      Int      @default(0)

  // Validity
  validFrom         DateTime
  validUntil        DateTime

  // Status
  status            CouponStatus @default(ACTIVE)

  // Applicability
  applicableToNewUsers Boolean @default(false)
  excludedCategories String[]
  excludedProducts   String[]

  isDeleted         Boolean  @default(false)
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  orders            Order[]
  userCoupons       UserCouponUsage[]

  @@index([code])
  @@index([status])
  @@index([validFrom])
  @@index([validUntil])
  @@index([isDeleted])
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  BUY_ONE_GET_ONE
}

enum CouponStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  EXHAUSTED
}

model UserCouponUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  usedCount Int      @default(0)
  lastUsedAt DateTime?
  createdAt DateTime @default(now())

  @@unique([userId, couponId])
  @@index([userId])
  @@index([couponId])
}

// ============================================================================
// REVIEWS & RATINGS
// ============================================================================

model Review {
  id        String   @id @default(cuid())

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  kitId     String?
  kit       IotKit?  @relation(fields: [kitId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Review content
  rating    Int      // 1-5
  title     String
  content   String   @db.Text

  // Helpfulness
  helpfulCount Int   @default(0)
  unhelpfulCount Int @default(0)

  // Status
  status    ReviewStatus @default(PENDING)
  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([kitId])
  @@index([userId])
  @@index([rating])
  @@index([status])
  @@index([isDeleted])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

// ============================================================================
// WEBSITE SETTINGS & CONFIGURATION
// ============================================================================

model WebsiteSettings {
  id                    String   @id @default(cuid())

  // Store information
  storeName             String   @default("A.K.R Electronics")
  storeDescription      String?
  logo                  String?
  favicon               String?

  // Contact details
  phone                 String?
  email                 String?
  address               String?

  // Business settings
  taxRate               Decimal  @db.Decimal(5, 2) @default(18.00)
  defaultShippingCost   Decimal  @db.Decimal(10, 2) @default(0)
  freeshippingThreshold Decimal? @db.Decimal(12, 2)

  // Theme & appearance
  primaryColor          String   @default("#0066FF")
  secondaryColor        String   @default("#FF6B35")
  accentColor           String   @default("#00D9FF")

  // SEO settings
  seoDefaultTitle       String?
  seoDefaultDescription String?
  seoDefaultKeywords    String?
  siteUrl               String?

  // Social links
  facebookUrl           String?
  twitterUrl            String?
  instagramUrl          String?
  linkedinUrl           String?
  youtubeUrl            String?

  // Policies
  termsUrl              String?
  privacyUrl            String?
  returnPolicyUrl       String?

  // Features
  enableReviews         Boolean  @default(true)
  enableWishlist        Boolean  @default(true)
  enableComparison      Boolean  @default(false)
  enableNewsletter      Boolean  @default(true)

  // Maintenance
  maintenanceMode       Boolean  @default(false)
  maintenanceMessage    String?

  updatedAt             DateTime @updatedAt
}

// ============================================================================
// HOMEPAGE CONFIGURATION
// ============================================================================

model HomepageSection {
  id              String   @id @default(cuid())

  // Section type
  type            SectionType
  title           String?
  subtitle        String?
  description     String?

  // Content configuration
  content         Json?    // Flexible content based on section type

  // Display settings
  displayOrder    Int      @default(0)
  isVisible       Boolean  @default(true)

  // Styling
  backgroundColor String?
  textColor       String?
  customCss       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([isVisible])
  @@index([displayOrder])
}

enum SectionType {
  HERO_BANNER
  FEATURED_PRODUCTS
  CATEGORIES
  NEW_ARRIVALS
  BESTSELLERS
  SPECIAL_OFFERS
  TESTIMONIALS
  NEWSLETTER_SIGNUP
  ANNOUNCEMENT
  CUSTOM_HTML
  IMAGE_GALLERY
  VIDEO
}

model Banner {
  id              String   @id @default(cuid())
  title           String
  subtitle        String?
  description     String?

  // Media
  imageUrl        String
  mobileImageUrl  String?
  videoUrl        String?

  // Link
  linkUrl         String?
  linkText        String?

  // Display settings
  displayOrder    Int      @default(0)
  isActive        Boolean  @default(true)
  startDate       DateTime?
  endDate         DateTime?

  // Styling
  backgroundColor String?
  textAlignment   String?  @default("center")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
  @@index([displayOrder])
  @@index([startDate])
  @@index([endDate])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  message     String   @db.Text
  type        AnnouncementType

  // Display settings
  isActive    Boolean  @default(true)
  startDate   DateTime?
  endDate     DateTime?

  // Visual
  backgroundColor String?
  textColor   String?
  icon        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([startDate])
  @@index([endDate])
}

enum AnnouncementType {
  INFO
  WARNING
  SUCCESS
  ERROR
  MAINTENANCE
}

// ============================================================================
// AUDIT & LOGGING
// ============================================================================

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?
  action        String
  resourceType  String
  resourceId    String

  // Changes
  oldValues     Json?
  newValues     Json?

  metadata      Json?
  ipAddress     String?
  userAgent     String?

  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@index([createdAt])
}
